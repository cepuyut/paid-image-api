{
  "openapi": "3.1.0",
  "info": {
    "title": "Paid Image API",
    "version": "1.0.0",
    "description": "AI image generation API monetized via MPP (Machine Payments Protocol). Pay-per-request with Tempo blockchain.",
    "x-guidance": "This API generates images from text prompts. Send a POST to /v1/images/generate with a prompt. You will receive a 402 Payment Required with a challenge. Pay per model: Schnell $0.03, Dev $0.05, Pro $0.10 pathUSD via Tempo blockchain, then retry with the payment credential to receive your generated image. Check GET /v1/prices for current pricing."
  },
  "x-discovery": {
    "ownershipProofs": ["dns:paid-image-api.onrender.com"]
  },
  "x-service-info": {
    "categories": ["media", "compute"],
    "docs": {
      "homepage": "https://paid-image-api.onrender.com",
      "llms": "https://paid-image-api.onrender.com/llms.txt",
      "apiReference": "https://paid-image-api.onrender.com/openapi.json"
    }
  },
  "servers": [
    {
      "url": "https://paid-image-api.onrender.com"
    }
  ],
  "paths": {
    "/v1/images/generate": {
      "post": {
        "operationId": "generateImage",
        "summary": "Generate an image from a text prompt",
        "description": "Generates images from text prompts using AI models. Each request costs 0.08 pathUSD, paid via MPP Tempo charge.",
        "x-payment-info": {
          "protocols": ["mpp"],
          "pricingMode": "tiered",
          "priceRange": { "min": "0.030000", "max": "0.100000" },
          "tiers": [
            { "model": "fal-ai/flux/schnell", "tier": "schnell", "price": "0.030000" },
            { "model": "fal-ai/flux/dev", "tier": "dev", "price": "0.050000" },
            { "model": "gemini-3-pro-image-preview", "tier": "dev", "price": "0.050000" },
            { "model": "fal-ai/flux-pro/v1.1", "tier": "pro", "price": "0.100000" }
          ]
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "prompt": {
                    "type": "string",
                    "description": "Text prompt describing the image to generate",
                    "example": "A serene mountain landscape at sunset with a lake reflection"
                  },
                  "model": {
                    "type": "string",
                    "description": "Model identifier. Pricing varies by model: fal-ai/flux/schnell ($0.03), fal-ai/flux/dev ($0.05), gemini-3-pro-image-preview ($0.05), fal-ai/flux-pro/v1.1 ($0.10)",
                    "default": "gemini-3-pro-image-preview",
                    "enum": ["fal-ai/flux/schnell", "fal-ai/flux/dev", "fal-ai/flux-pro/v1.1", "gemini-3-pro-image-preview"]
                  },
                  "image_size": {
                    "type": "string",
                    "description": "Output image size",
                    "default": "1024x1024",
                    "enum": ["512x512", "1024x1024", "1792x1024"]
                  },
                  "num_images": {
                    "type": "integer",
                    "description": "Number of images to generate (1-4)",
                    "default": 1,
                    "minimum": 1,
                    "maximum": 4
                  }
                },
                "required": ["prompt"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Image generated successfully",
            "headers": {
              "Payment-Receipt": {
                "description": "Base64url-encoded payment receipt",
                "schema": { "type": "string" }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "images": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "url": { "type": "string", "format": "uri" },
                          "width": { "type": "integer" },
                          "height": { "type": "integer" },
                          "content_type": { "type": "string" }
                        }
                      }
                    },
                    "prompt": { "type": "string" },
                    "model": { "type": "string" },
                    "timings": { "type": "object" }
                  }
                }
              }
            }
          },
          "402": {
            "description": "Payment Required – respond with Authorization: Payment credential",
            "headers": {
              "WWW-Authenticate": {
                "description": "MPP payment challenge",
                "schema": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
