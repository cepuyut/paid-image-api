# Image backend: "bluesminds" (default) or "fal"
IMAGE_BACKEND=bluesminds

# Bluesminds API (OpenAI-compatible)
BLUESMINDS_KEY=
BLUESMINDS_BASE=https://api.bluesminds.com/v1

# fal.ai API key (optional, used when IMAGE_BACKEND=fal)
FAL_KEY=

# Wallet address to receive payments
WALLET_ADDRESS=0x8009c928c37285dc7e6e0527c3ac36d7a930e4eb

# pathUSD token contract on Tempo mainnet
CURRENCY_TOKEN=0x20c000000000000000000000b9537d11c60e8b50

# Pricing is tiered per model (hardcoded in src/index.js)
# Schnell: $0.03 | Dev: $0.05 | Pro: $0.10

# Server
PORT=3000
HOST=http://localhost:3000

# MPP
MPP_REALM=paid-image-api
MPP_CHALLENGE_SECRET=replace-with-a-random-secret
MPP_CHALLENGE_TTL=300
TEMPO_CHAIN_ID=42431
