# Tempo wallet private key — used to RECEIVE user payments AND PAY fal.ai via MPP
# One wallet, funds cycle automatically: user → wallet → fal.ai, profit stays in wallet
WALLET_PRIVATE_KEY=0x...

# Wallet address to receive payments (derived from the private key above)
WALLET_ADDRESS=0xf48c6E46358652fC77462d56d609B8bC7f4ba82e

# USDC token contract on Tempo mainnet
CURRENCY_TOKEN=0x20c000000000000000000000b9537d11c60e8b50

# Pricing is tiered per model (hardcoded in src/index.js)
# Schnell: $0.03 | Dev: $0.05 | Recraft: $0.06 | HiDream: $0.08 | Ideogram: $0.08 | Pro: $0.10

# Upstash Redis (gallery persistence)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Server
PORT=10000
HOST=http://localhost:10000

# MPP
MPP_REALM=pixelpayapi.com
MPP_CHALLENGE_SECRET=replace-with-a-random-secret
MPP_CHALLENGE_TTL=300
TEMPO_CHAIN_ID=4217

# NFT Infrastructure
PINATA_JWT=your-pinata-jwt-here
NFT_CONTRACT_ADDRESS=0x...deployed-nft-contract
MARKETPLACE_CONTRACT_ADDRESS=0x...deployed-marketplace-contract
